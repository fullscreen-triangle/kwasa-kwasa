{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Turbulance",
    "patterns": [
        { "include": "#keywords" },
        { "include": "#strings" },
        { "include": "#comments" },
        { "include": "#numbers" },
        { "include": "#operators" },
        { "include": "#functions" },
        { "include": "#propositions" },
        { "include": "#evidence" },
        { "include": "#metacognitive" }
    ],
    "repository": {
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.turbulance",
                    "match": "\\b(given|within|considering|otherwise|for|each|while|try|catch|finally|return|break|continue|import|from|export|async|await|parallel)\\b"
                },
                {
                    "name": "keyword.declaration.turbulance",
                    "match": "\\b(funxn|item|const|var|proposition|motion|evidence|metacognitive|test|property)\\b"
                },
                {
                    "name": "keyword.other.turbulance",
                    "match": "\\b(support|refute|validate|assert|track|evaluate|ensure|debug|pass)\\b"
                },
                {
                    "name": "constant.language.turbulance",
                    "match": "\\b(true|false|null|undefined)\\b"
                },
                {
                    "name": "storage.type.turbulance",
                    "match": "\\b(String|Integer|Float|Boolean|List|Dict|Set|Any|Function|TextUnit|Pattern|Evidence|Proposition|Context)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.turbulance",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.turbulance",
                            "match": "\\\\."
                        },
                        {
                            "name": "constant.other.placeholder.turbulance",
                            "match": "\\{[^}]*\\}"
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.turbulance",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.turbulance",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.turbulance",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.turbulance",
                    "begin": "/\\*",
                    "end": "\\*/"
                },
                {
                    "name": "comment.block.documentation.turbulance",
                    "begin": "///",
                    "end": "$",
                    "patterns": [
                        {
                            "name": "markup.bold.turbulance",
                            "match": "\\*\\*[^*]+\\*\\*"
                        },
                        {
                            "name": "markup.italic.turbulance",
                            "match": "\\*[^*]+\\*"
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.turbulance",
                    "match": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b"
                },
                {
                    "name": "constant.numeric.hex.turbulance",
                    "match": "\\b0[xX][0-9a-fA-F]+\\b"
                },
                {
                    "name": "constant.numeric.binary.turbulance",
                    "match": "\\b0[bB][01]+\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arithmetic.turbulance",
                    "match": "\\+|\\-|\\*|\\/|\\%|\\*\\*"
                },
                {
                    "name": "keyword.operator.comparison.turbulance",
                    "match": "==|!=|<|>|<=|>=|in|not in|is|is not"
                },
                {
                    "name": "keyword.operator.logical.turbulance",
                    "match": "\\band\\b|\\bor\\b|\\bnot\\b"
                },
                {
                    "name": "keyword.operator.assignment.turbulance",
                    "match": "=|\\+=|\\-=|\\*=|\\/=|\\%="
                },
                {
                    "name": "keyword.operator.semantic.turbulance",
                    "match": "\\bmatches\\b|\\bcontains\\b|\\bdivide\\b|\\bmultiply\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.turbulance",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()"
                },
                {
                    "name": "support.function.builtin.turbulance",
                    "match": "\\b(print|len|range|min|max|sum|mean|std|var|median|mode|quantile|normalize|tokenize|stem|lemmatize|extract_keywords|sentiment_analysis|readability_score|contains|matches|split|join|strip|lower|upper|title|replace|find|count|load_file|save_file|load_json|save_json|load_csv|save_csv|http_get|http_post|parse_html|extract_links|search_pubmed|calculate_gc_content|align_sequences|call_variants|analyze_spectrum|peak_detection|baseline_correction|classify_structure|predict_properties)\\b"
                }
            ]
        },
        "propositions": {
            "patterns": [
                {
                    "name": "entity.name.type.proposition.turbulance",
                    "begin": "\\b(proposition)\\s+([A-Z][a-zA-Z0-9_]*)",
                    "beginCaptures": {
                        "1": { "name": "keyword.declaration.turbulance" },
                        "2": { "name": "entity.name.type.proposition.turbulance" }
                    },
                    "end": "(?=\\bproposition\\b|$)",
                    "patterns": [
                        {
                            "name": "entity.name.function.motion.turbulance",
                            "begin": "\\b(motion)\\s+([A-Z][a-zA-Z0-9_]*)",
                            "beginCaptures": {
                                "1": { "name": "keyword.declaration.turbulance" },
                                "2": { "name": "entity.name.function.motion.turbulance" }
                            },
                            "end": "$",
                            "patterns": [
                                { "include": "#strings" }
                            ]
                        },
                        { "include": "$self" }
                    ]
                }
            ]
        },
        "evidence": {
            "patterns": [
                {
                    "name": "entity.name.type.evidence.turbulance",
                    "begin": "\\b(evidence)\\s+([A-Z][a-zA-Z0-9_]*)",
                    "beginCaptures": {
                        "1": { "name": "keyword.declaration.turbulance" },
                        "2": { "name": "entity.name.type.evidence.turbulance" }
                    },
                    "end": "(?=\\bevidence\\b|$)",
                    "patterns": [
                        {
                            "name": "support.type.property-name.turbulance",
                            "match": "\\b(sources|collection|processing|validation)\\b:"
                        },
                        { "include": "$self" }
                    ]
                }
            ]
        },
        "metacognitive": {
            "patterns": [
                {
                    "name": "entity.name.type.metacognitive.turbulance",
                    "begin": "\\b(metacognitive)\\s+([A-Z][a-zA-Z0-9_]*)",
                    "beginCaptures": {
                        "1": { "name": "keyword.declaration.turbulance" },
                        "2": { "name": "entity.name.type.metacognitive.turbulance" }
                    },
                    "end": "(?=\\bmetacognitive\\b|$)",
                    "patterns": [
                        {
                            "name": "support.type.property-name.turbulance",
                            "match": "\\b(track|evaluate|reflect|learn)\\b:"
                        },
                        { "include": "$self" }
                    ]
                }
            ]
        }
    },
    "scopeName": "source.turbulance"
}
