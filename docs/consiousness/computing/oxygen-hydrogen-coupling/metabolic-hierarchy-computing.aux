\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Metabolic flux hierarchy: Multi-scale information cascades through metabolic pathways.} \textbf  {(A)} Hierarchical flux cascade: Baseline (blue) achieves 61.7\% end-to-end flux ratio across all 5 levels. Metformin (green) restores flux propagation (87.6\% at L3, 75.6\% at L4). Insulin resistance (red) exhibits 70\% collapse at L4 (OxPhos), demonstrating hierarchical dysfunction. Lithium (purple) shows partial restoration. \textbf  {(B)} Information compression: Healthy metabolism compresses 8 bits (L1) → 3 bits (L5), yielding 7.29 bits total information. Insulin resistance fails compression (0.04 bits), metformin restores to 4.95 bits. \textbf  {(C)} ATP production/consumption: Baseline net=1722 ATP, metformin=2870 ATP (67\% increase), insulin resistance=499 ATP (71\% decrease). \textbf  {(D)} Comprehensive efficiency: End-to-end flux ratio (baseline 0.30, metformin 0.62, insulin resistance 0.04), ATP efficiency (baseline 4.23 bits/kATP), and net ATP production demonstrate metformin's hierarchical restoration capability.}}{20}{figure.caption.6}\protected@file@percent }
\newlabel{fig:metabolic_flux_hierarchy}{{4}{20}{\textbf {Metabolic flux hierarchy: Multi-scale information cascades through metabolic pathways.} \textbf {(A)} Hierarchical flux cascade: Baseline (blue) achieves 61.7\% end-to-end flux ratio across all 5 levels. Metformin (green) restores flux propagation (87.6\% at L3, 75.6\% at L4). Insulin resistance (red) exhibits 70\% collapse at L4 (OxPhos), demonstrating hierarchical dysfunction. Lithium (purple) shows partial restoration. \textbf {(B)} Information compression: Healthy metabolism compresses 8 bits (L1) → 3 bits (L5), yielding 7.29 bits total information. Insulin resistance fails compression (0.04 bits), metformin restores to 4.95 bits. \textbf {(C)} ATP production/consumption: Baseline net=1722 ATP, metformin=2870 ATP (67\% increase), insulin resistance=499 ATP (71\% decrease). \textbf {(D)} Comprehensive efficiency: End-to-end flux ratio (baseline 0.30, metformin 0.62, insulin resistance 0.04), ATP efficiency (baseline 4.23 bits/kATP), and net ATP production demonstrate metformin's hierarchical restoration capability}{figure.caption.6}{}}
\newlabel{fig:metabolic_flux_hierarchy@cref}{{[figure][4][]4}{[1][19][]20}}
