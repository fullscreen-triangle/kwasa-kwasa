\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces \textbf  {Individuation by negation and the invariant region.} \textbf  {(A)}~The minimum-cut minimiser side $|S^\ast (v)|$ versus cluster size $k$ for the two-cluster construction: it equals $k>1$, so identity is a region, never a point (\Cref  {thm:region}). \textbf  {(B)}~$\sigma (v)$ after a random relabelling versus before: on the diagonal---identity is a relabelling invariant (\Cref  {thm:invariant}). \textbf  {(C)}~$|U|+|\complement U|$ versus $|V|$: on the diagonal, a part and its negation partition the whole exactly (\Cref  {thm:negation}). \textbf  {(D)}~The same in three coordinates $(|U|,|\complement U|,|V|)$, lying on the plane $|U|+|\complement U|=|V|$.}}{6}{figure.2}\protected@file@percent }
\newlabel{fig:panel2}{{2}{6}{\textbf {Individuation by negation and the invariant region.} \textbf {(A)}~The minimum-cut minimiser side $|S^\ast (v)|$ versus cluster size $k$ for the two-cluster construction: it equals $k>1$, so identity is a region, never a point (\Cref {thm:region}). \textbf {(B)}~$\sigma (v)$ after a random relabelling versus before: on the diagonal---identity is a relabelling invariant (\Cref {thm:invariant}). \textbf {(C)}~$|U|+|\complement U|$ versus $|V|$: on the diagonal, a part and its negation partition the whole exactly (\Cref {thm:negation}). \textbf {(D)}~The same in three coordinates $(|U|,|\complement U|,|V|)$, lying on the plane $|U|+|\complement U|=|V|$}{figure.2}{}}
