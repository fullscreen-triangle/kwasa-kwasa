\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {The floor and granular meaning} (computed on finite weighted graphs; exact minimum cuts). \textbf  {(A)}~Separation cost $\sigma (v)$ for every item of ${\sim }220$ random contact graphs versus graph size; every point lies on or above the floor $\beta $ (red), independent of size---no sharp cut (\Cref  {thm:floor}). \textbf  {(B)}~Distribution of $\sigma (v)/\beta $, supported entirely at and above $1$. \textbf  {(C)}~Alignment score $a(x,y)$ versus the floor $\beta /\Omega $; every point lies above the diagonal, the bound $a\ge \beta /\Omega $ (\Cref  {lem:align-floor}). \textbf  {(D)}~The realised floor $\min _v\sigma (v)$ over graph size and $\beta $: strictly positive throughout, rising with $\beta $.}}{5}{figure.1}\protected@file@percent }
\newlabel{fig:panel1}{{1}{5}{\textbf {The floor and granular meaning} (computed on finite weighted graphs; exact minimum cuts). \textbf {(A)}~Separation cost $\sigma (v)$ for every item of ${\sim }220$ random contact graphs versus graph size; every point lies on or above the floor $\flo $ (red), independent of size---no sharp cut (\Cref {thm:floor}). \textbf {(B)}~Distribution of $\sigma (v)/\flo $, supported entirely at and above $1$. \textbf {(C)}~Alignment score $\al (x,y)$ versus the floor $\flo /\Om $; every point lies above the diagonal, the bound $\al \ge \flo /\Om $ (\Cref {lem:align-floor}). \textbf {(D)}~The realised floor $\min _v\sigma (v)$ over graph size and $\flo $: strictly positive throughout, rising with $\flo $}{figure.1}{}}
\newlabel{fig:panel1@cref}{{[figure][1][]1}{[1][4][]5}{}{}{}}
