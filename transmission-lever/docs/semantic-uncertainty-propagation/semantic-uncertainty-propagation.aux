\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Propagation, the monotone record, and the relaxation.} \textbf  {(A)}~The committed record $M$ along a walk (blue), strictly increasing; red marks revisited vertices---recurrence of position is not return of state (\Cref  {thm:monotone}). \textbf  {(B)}~Cross-demand $D$ along the relaxation: one instance reaches $0$ (quiescence, teal), one plateaus at the floor (non-halt $\to $ decline, orange) (\Cref  {thm:dichotomy,thm:two-kinds}). \textbf  {(C)}~Residual above floor for several seeds, each descending to $0$. \textbf  {(D)}~The demand surface $D(\text  {step},D_0)$: monotone descent to the floor.}}{14}{figure.3}\protected@file@percent }
