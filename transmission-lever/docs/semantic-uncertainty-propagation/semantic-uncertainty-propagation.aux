\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Route-audit, names, and the master equivalence.} \textbf  {(A)}~Central (content) demand versus response demand: proper pairs (blue) sit at the origin, false friends (orange) have near-zero central demand---invisible to an endpoint check---but large response demand, caught by the four-column route-audit (\Cref  {thm:false-friend}). \textbf  {(B)}~A compound's cut $\sigma (U)$ (blue, flat at $2\beta $) versus the composition of its constituents' cuts (orange, rising): names are non-compositional (\Cref  {thm:non-derivable}). \textbf  {(C)}~The realised floor $\min _v\sigma $ versus $\beta $: positive for $\beta >0$, vanishing (a sharp cut, red) only at $\beta =0$---the master equivalence (\Cref  {thm:master}). \textbf  {(D)}~The same non-compositionality in three coordinates $(W,\sigma (U),\text  {composition})$.}}{16}{figure.4}\protected@file@percent }
\newlabel{fig:panel4}{{4}{16}{\textbf {Route-audit, names, and the master equivalence.} \textbf {(A)}~Central (content) demand versus response demand: proper pairs (blue) sit at the origin, false friends (orange) have near-zero central demand---invisible to an endpoint check---but large response demand, caught by the four-column route-audit (\Cref {thm:false-friend}). \textbf {(B)}~A compound's cut $\sigma (U)$ (blue, flat at $2\flo $) versus the composition of its constituents' cuts (orange, rising): names are non-compositional (\Cref {thm:non-derivable}). \textbf {(C)}~The realised floor $\min _v\sigma $ versus $\flo $: positive for $\flo >0$, vanishing (a sharp cut, red) only at $\flo =0$---the master equivalence (\Cref {thm:master}). \textbf {(D)}~The same non-compositionality in three coordinates $(W,\sigma (U),\text {composition})$}{figure.4}{}}
\newlabel{fig:panel4@cref}{{[figure][4][]4}{[1][15][]16}{}{}{}}
